# Copy this file to ".env" and adjust if needed. The application reads these
# values at startup (see app/config.py). Defaults already match docker-compose,
# so for a local run you usually do not need to change anything.

# --- PostgreSQL (primary data store) ---
DATABASE_URL=postgresql://typeahead:typeahead@localhost:5433/typeahead

# --- Redis logical cache nodes (comma-separated host:port list) ---
# The order does NOT matter; consistent hashing places each node on a ring.
REDIS_NODES=localhost:6391,localhost:6392,localhost:6393

# --- Cache behaviour ---
CACHE_TTL_SECONDS=30        # How long a cached suggestion list stays valid.
VIRTUAL_NODES=150           # Virtual nodes per physical node on the hash ring.

# --- Suggestions ---
SUGGESTION_LIMIT=10         # Max suggestions returned by GET /suggest.
MAX_PREFIX_LEN=12           # Longest prefix we cache / invalidate.

# --- Trending / recency-aware ranking ---
DEFAULT_RANKING_MODE=trending  # "basic" (count only) or "trending" (recency-aware).
RECENCY_ALPHA=2000.0           # Weight of recent activity relative to all-time count.
RECENCY_HALFLIFE_SECONDS=600   # Recent-activity score halves every 10 minutes.

# --- Batch writes ---
BATCH_SIZE=500              # Flush when this many distinct queries are buffered.
FLUSH_INTERVAL_SECONDS=2.0  # ...or at least this often, whichever comes first.
